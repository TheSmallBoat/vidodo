{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "av.trace.trace-manifest.v0",
    "title": "Trace Manifest",
    "description": "Manifest for a trace bundle generated by a run.",
    "type": "object",
    "required": [
        "trace_bundle_id",
        "show_id",
        "revision",
        "run_id",
        "mode",
        "status",
        "input_refs"
    ],
    "properties": {
        "trace_bundle_id": {
            "type": "string"
        },
        "show_id": {
            "type": "string"
        },
        "revision": {
            "type": "integer",
            "minimum": 0
        },
        "run_id": {
            "type": "string"
        },
        "mode": {
            "type": "string"
        },
        "started_at": {
            "type": "string"
        },
        "completed_at": {
            "type": "string"
        },
        "status": {
            "type": "string"
        },
        "input_refs": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "event_log_ref": {
            "type": "string"
        },
        "metrics_ref": {
            "type": "string"
        },
        "evaluation_ref": {
            "type": "string"
        }
    },
    "additionalProperties": false
}