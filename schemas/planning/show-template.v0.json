{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "av.planning.show-template.v0",
    "title": "Show Template",
    "description": "Reusable show template with section references, default parameters, and scene pack bindings.",
    "type": "object",
    "required": [
        "type",
        "template_id",
        "name",
        "mode",
        "sections",
        "default_params"
    ],
    "properties": {
        "type": {
            "type": "string",
            "const": "show_template"
        },
        "template_id": {
            "type": "string"
        },
        "name": {
            "type": "string",
            "minLength": 1
        },
        "description": {
            "type": "string"
        },
        "mode": {
            "type": "string",
            "enum": [
                "live",
                "offline_render",
                "rehearsal"
            ]
        },
        "sections": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "required": [
                    "section_id",
                    "order",
                    "label"
                ],
                "properties": {
                    "section_id": {
                        "type": "string"
                    },
                    "order": {
                        "type": "integer",
                        "minimum": 0
                    },
                    "label": {
                        "type": "string"
                    },
                    "duration_bars": {
                        "type": "integer",
                        "minimum": 1
                    },
                    "scene_pack_ref": {
                        "type": "string"
                    },
                    "energy_target": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 1
                    }
                },
                "additionalProperties": false
            }
        },
        "default_params": {
            "type": "object",
            "required": [
                "tempo_bpm",
                "time_signature"
            ],
            "properties": {
                "tempo_bpm": {
                    "type": "number",
                    "exclusiveMinimum": 0
                },
                "time_signature": {
                    "type": "array",
                    "items": {
                        "type": "integer",
                        "minimum": 1
                    },
                    "minItems": 2,
                    "maxItems": 2
                },
                "style_tags": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            },
            "additionalProperties": false
        },
        "scene_pack_refs": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "tags": {
            "type": "array",
            "items": {
                "type": "string"
            }
        }
    },
    "additionalProperties": false
}