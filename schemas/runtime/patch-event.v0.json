{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "av.runtime.patch-event.v0",
    "title": "Patch Event",
    "description": "Runtime patch lifecycle payload.",
    "type": "object",
    "required": [
        "patch_id",
        "scope",
        "effective_revision",
        "fallback_revision"
    ],
    "properties": {
        "patch_id": {
            "type": "string"
        },
        "scope": {
            "type": "object",
            "description": "Structured patch scope matching live-patch-proposal scope for full traceability.",
            "required": [
                "from_bar",
                "to_bar",
                "window"
            ],
            "properties": {
                "from_bar": {
                    "type": "integer",
                    "minimum": 0
                },
                "to_bar": {
                    "type": "integer",
                    "minimum": 0
                },
                "window": {
                    "type": "string"
                }
            },
            "additionalProperties": false
        },
        "effective_revision": {
            "type": "integer",
            "minimum": 0
        },
        "fallback_revision": {
            "type": "integer",
            "minimum": 0
        },
        "decision": {
            "type": "string",
            "enum": [
                "proposed",
                "accepted",
                "rejected",
                "applied",
                "rolled_back"
            ]
        },
        "reason": {
            "type": "string"
        }
    },
    "additionalProperties": false
}