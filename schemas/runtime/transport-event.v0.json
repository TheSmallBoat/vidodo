{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "av.runtime.transport-event.v0",
    "title": "Transport Event",
    "description": "Runtime transport control payload.",
    "type": "object",
    "required": [
        "op"
    ],
    "properties": {
        "op": {
            "type": "string",
            "enum": [
                "play",
                "pause",
                "seek",
                "stop"
            ]
        },
        "target_bar": {
            "type": "integer",
            "minimum": 1
        },
        "target_beat": {
            "type": "number",
            "minimum": 0
        },
        "resume_revision": {
            "type": "integer",
            "minimum": 0
        },
        "reason": {
            "type": "string"
        }
    },
    "additionalProperties": false
}