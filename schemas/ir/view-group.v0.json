{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "av.ir.view-group.v0",
    "title": "View Group",
    "description": "Predefined view set mapped onto a display topology.",
    "type": "object",
    "required": [
        "view_group_id",
        "scene_ref",
        "display_topology_ref",
        "views"
    ],
    "properties": {
        "view_group_id": {
            "type": "string"
        },
        "scene_ref": {
            "type": "string"
        },
        "display_topology_ref": {
            "type": "string"
        },
        "views": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "view_id",
                    "camera_id",
                    "display_id"
                ],
                "properties": {
                    "view_id": {
                        "type": "string"
                    },
                    "camera_id": {
                        "type": "string"
                    },
                    "display_id": {
                        "type": "string"
                    },
                    "frustum_ref": {
                        "type": "string"
                    },
                    "viewport": {
                        "type": "object",
                        "properties": {
                            "x": {
                                "type": "integer",
                                "minimum": 0
                            },
                            "y": {
                                "type": "integer",
                                "minimum": 0
                            },
                            "width": {
                                "type": "integer",
                                "minimum": 1
                            },
                            "height": {
                                "type": "integer",
                                "minimum": 1
                            }
                        },
                        "additionalProperties": false
                    }
                },
                "additionalProperties": false
            }
        }
    },
    "additionalProperties": false
}